{
  "name": "encomenda-rabbit-sink-connector",
  "config": {
    "connector.class": "com.github.jcustenborder.kafka.connect.rabbitmq.RabbitMQSinkConnector",
    "tasks.max": "1",
    "topics": "encomenda.recebida",
    "rabbitmq.username": "guest",
