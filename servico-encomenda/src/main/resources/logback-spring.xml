<configuration>
  <springProperty scope="context" name="serviceName" source="spring.application.name" defaultValue="servico-encomenda"/>
  <springProperty scope="context" name="environmentName" source="spring.profiles.active" defaultValue="local"/>

  <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="net.logstash.logback.encoder.LogstashEncoder">
      <timeZone>UTC</timeZone>
      <customFields>{"service":"${serviceName}","env":"${environmentName}"}</customFields>
      <includeMdc>true</includeMdc>
      <includeContext>false</includeContext>
      <mdcKeyFieldName>traceId=trace_id</mdcKeyFieldName>
      <mdcKeyFieldName>spanId=span_id</mdcKeyFieldName>
      <fieldNames>
        <logger>logger</logger>
        <thread>thread</thread>
      </fieldNames>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="JSON_CONSOLE"/>
  </root>
</configuration>
